POST {{baseUrl}}/lenders/761c866f-57c4-4d4d-b292-09e670ecbdcf/transactions
Content-Type: application/json

{
  "idLender": "761c866f-57c4-4d4d-b292-09e670ecbdcf",
  "transactionPaymentType": "MONEY",
  "transactionType": "BORROWED",
  "transactionValue": 20.0
}

