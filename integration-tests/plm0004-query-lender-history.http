@baseUrl = http://localhost:9094
@contentType = application/json
@lenderId1 = abcddac5-e8d7-490e-9532-48dc6d53b81f
@lenderId2 = e8a11ae9-2826-4460-bd3e-d8de4a4f5432
@lenderId3 = d99f0973-92a7-495f-811a-7154983e8e4c


### Actuator
GET {{baseUrl}}/actuator
Accept: application/json

### ============================================
### CREATE LENDERS
### ============================================

### Create Lender #1 - John Doe (1 settlement)
POST {{baseUrl}}/lenders
Content-Type: {{contentType}}

{
  "name": "John Doe",
  "phone": "+351911111111",
  "bankData": "IBAN:PT000000000000000001",
  "address": "123 Main Street"
}

### Create Lender #2 - Jane Smith (3 settlements)
POST {{baseUrl}}/lenders
Content-Type: {{contentType}}

{
  "name": "Jane Smith",
  "phone": "+351922222222",
  "bankData": "IBAN:PT000000000000000002",
  "address": "456 Oak Avenue"
}

### Create Lender #3 - Bob Wilson (5 settlements)
POST {{baseUrl}}/lenders
Content-Type: {{contentType}}

{
  "name": "Bob Wilson",
  "phone": "+351933333333",
  "bankData": "IBAN:PT000000000000000003",
  "address": "789 Pine Road"
}

### ============================================
### CREATE SETTLEMENTS FOR LENDER 1 (John Doe)
### ============================================

### Create transaction for John Doe
POST {{baseUrl}}/lenders/{{lenderId1}}/transactions
Content-Type: {{contentType}}

{
  "idLender": "{{lenderId1}}",
  "transactionPaymentType": "MONEY",
  "transactionType": "BORROWED",
  "transactionValue": 100.00
}

### Settle John Doe (1 settlement)
POST {{baseUrl}}/lenders/settle
Content-Type: {{contentType}}

{
  "lenderId": "{{lenderId1}}",
  "settlementType": "PAID_IN_FULL",
  "paymentType": "MONEY"
}

